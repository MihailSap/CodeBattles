{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "scss:types": "typed-scss-modules \"src/**/*.module.scss\" --exportType default --nameFormat camel --implementation sass",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@monaco-editor/react": "4.7.0",
    "@reduxjs/toolkit": "2.11.2",
    "axios": "1.16.1",
    "react": "19.2.4",
    "react-datepicker": "9.1.0",
    "react-dom": "19.2.4",
    "react-hook-form": "7.76.0",
    "react-redux": "9.2.0",
    "react-router-dom": "7.13.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "25.9.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "prettier": "3.8.3",
    "sass": "1.99.0",
    "typed-scss-modules": "5.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vite": "8.0.13"
  },
  "overrides": {
    "brace-expansion": "1.1.14",
    "dompurify": "3.4.0",
    "esbuild": "0.28.0",
    "postcss": "8.5.15"
  }
}
